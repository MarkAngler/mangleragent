# Required — your Anthropic / Claude API key (powers Mangler and orchestrated agents).
# ANTHROPIC_API_KEY also works.
CLAUDE_API_KEY=sk-ant-...

# Optional — route Mangler through the Databricks AI Gateway instead of the direct
# Anthropic API (select "Databricks AI Gateway" in Settings). Both are required.
# The scheme is optional on the host. DATABRICKS_WORKSPACE / DATABRICKS_PAT are
# accepted as aliases.
# DATABRICKS_HOST=https://dbc-xxxxxxxx-xxxx.cloud.databricks.com
# DATABRICKS_TOKEN=dapi...

# Optional — enables the honcho.dev memory integration (toggle it on in Settings).
HONCHO_DEV_API_KEY=

# Optional overrides
# PORT=4173
# MANGLED_DATA_DIR=~/.mangled-agents
# MANGLED_CLAUDE_BIN=claude
# MANGLED_CODEX_BIN=codex
# MANGLED_CODE_BIN=code
# Fallback for the honcho workspace; also settable in Settings, which takes precedence.
# MANGLED_HONCHO_WORKSPACE=mangled-agents
